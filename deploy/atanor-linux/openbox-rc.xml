<?xml version="1.0" encoding="UTF-8"?>
<!-- ATANOR desktop window management: Windows-like semantics on our theme.
     Title buttons right (min/max/close), Alt-Tab cycling, Super opens the
     start menu (jgmenu), one workspace - a desktop, not a research toy. -->
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <resistance><strength>10</strength><screen_edge_strength>20</screen_edge_strength></resistance>
  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
  </focus>
  <placement><policy>Smart</policy><center>yes</center></placement>
  <theme>
    <name>ATANOR</name>
    <titleLayout>NLIMC</titleLayout>
    <!-- keepBorder=no: HONOR the client's MOTIF 'no decorations' hint. yes made
         openbox keep the titlebar despite the wallpaper's correctly-set MOTIF —
         the true root cause of the persistent titlebar (the strip WAS working;
         openbox was overriding it). Normal windows keep their border because
         they never request no-decor. -->
    <keepBorder>no</keepBorder>
    <animateIconify>yes</animateIconify>
    <font place="ActiveWindow"><name>Noto Sans CJK KR</name><size>10</size><weight>Bold</weight></font>
    <font place="InactiveWindow"><name>Noto Sans CJK KR</name><size>10</size></font>
    <font place="MenuHeader"><name>Noto Sans CJK KR</name><size>10</size></font>
    <font place="MenuItem"><name>Noto Sans CJK KR</name><size>10</size></font>
    <font place="ActiveOnScreenDisplay"><name>Noto Sans CJK KR</name><size>10</size><weight>Bold</weight></font>
    <font place="InactiveOnScreenDisplay"><name>Noto Sans CJK KR</name><size>10</size></font>
  </theme>
  <desktops><number>1</number><firstdesk>1</firstdesk><popupTime>0</popupTime></desktops>
  <resize><drawContents>yes</drawContents><popupShow>Nonpixel</popupShow></resize>
  <keyboard>
    <keybind key="A-Tab"><action name="NextWindow"><finalactions><action name="Focus"/><action name="Raise"/><action name="Unshade"/></finalactions></action></keybind>
    <keybind key="A-S-Tab"><action name="PreviousWindow"><finalactions><action name="Focus"/><action name="Raise"/><action name="Unshade"/></finalactions></action></keybind>
    <keybind key="A-F4"><action name="Close"/></keybind>
    <keybind key="W-e"><action name="Execute"><command>pcmanfm</command></action></keybind>
    <keybind key="W-Return"><action name="Execute"><command>x-terminal-emulator</command></action></keybind>
    <keybind key="Super_L"><action name="Execute"><command>jgmenu_run</command></action></keybind>
    <keybind key="W-Up"><action name="Maximize"/></keybind>
    <keybind key="W-Down"><action name="Unmaximize"/></keybind>
  </keyboard>
  <mouse>
    <dragThreshold>4</dragThreshold>
    <doubleClickTime>400</doubleClickTime>
    <context name="Titlebar">
      <mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="Left" action="Drag"><action name="Move"/></mousebind>
      <mousebind button="Left" action="DoubleClick"><action name="ToggleMaximize"/></mousebind>
    </context>
    <context name="Frame">
      <mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
    </context>
    <context name="Client">
      <mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
    </context>
    <context name="BLCorner"><mousebind button="Left" action="Drag"><action name="Resize"/></mousebind></context>
    <context name="BRCorner"><mousebind button="Left" action="Drag"><action name="Resize"/></mousebind></context>
    <context name="Bottom"><mousebind button="Left" action="Drag"><action name="Resize"><edge>bottom</edge></action></mousebind></context>
    <context name="Icon"><mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/><action name="ShowMenu"><menu>client-menu</menu></action></mousebind></context>
    <context name="AllDesktops"><mousebind button="Left" action="Click"><action name="ToggleOmnipresent"/></mousebind></context>
    <context name="Iconify"><mousebind button="Left" action="Click"><action name="Iconify"/></mousebind></context>
    <context name="Maximize"><mousebind button="Left" action="Click"><action name="ToggleMaximize"/></mousebind></context>
    <context name="Close"><mousebind button="Left" action="Click"><action name="Close"/></mousebind></context>
    <context name="Desktop">
      <mousebind button="Left" action="Press"><action name="Focus"/></mousebind>
    </context>
    <context name="Root">
      <mousebind button="Right" action="Press"><action name="ShowMenu"><menu>root-menu</menu></action></mousebind>
    </context>
  </mouse>
  <menu><file>menu.xml</file><hideDelay>200</hideDelay></menu>
  <applications>
    <!-- class matching works AT MAP TIME (the title is still a URL then; a
         post-map _NET_WM_WINDOW_TYPE retype is ignored by openbox — measured
         as a stray titlebar on the wallpaper). firefox sets it via its class flag. -->
    <application name="atanor-wallpaper">
      <decor>no</decor>
      <layer>below</layer>
      <desktop>all</desktop>
      <maximized>true</maximized>
      <skip_taskbar>yes</skip_taskbar>
      <skip_pager>yes</skip_pager>
    </application>
    <application class="atanor-wallpaper">
      <decor>no</decor>
      <layer>below</layer>
      <desktop>all</desktop>
      <maximized>true</maximized>
      <skip_taskbar>yes</skip_taskbar>
      <skip_pager>yes</skip_pager>
    </application>
  </applications>
</openbox_config>
