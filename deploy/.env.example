# ATANOR Cloud Brain — server env. Copy to .env and adjust.

# Keep the continuous public-web learning loop + relation discovery running.
ATANOR_AUTO_LEARN=1

# (Optional) If you later run MULTIPLE cloud instances and want them to federate
# through a central broker, point each at it:
# ATANOR_CLOUD_MODE=remote
# ATANOR_CLOUD_ENDPOINT=https://broker.yourdomain.com
# ATANOR_CLOUD_API_KEY=...

# (Optional) Pin the accumulated candidate store to an explicit path inside the
# /app/data volume (otherwise the default under /app/data is used).
# ATANOR_CANDIDATE_STORE_PATH=/app/data/cloud_brain/candidate_runs/cloud_live
