# ATANOR local development defaults.
# These values keep ATANOR local-first and do not enable public contribution.
ATANOR_CLOUD_PROVIDER=local
ATANOR_CLOUD_MODE=local_broker
ATANOR_CONTRIBUTION_ENABLED=false

# Optional Cloudflare remote broker mode.
# Set these only after a real Worker endpoint is deployed and verified.
# ATANOR_CLOUD_PROVIDER=cloudflare
# ATANOR_CLOUD_MODE=remote
# ATANOR_CLOUD_ENDPOINT=https://your-worker.workers.dev
# ATANOR_CLOUD_API_KEY=
# ATANOR_NODE_ID=atanor-local-peer
# ATANOR_CONTRIBUTION_ENABLED=true
# ATANOR_CLOUD_TIMEOUT_SECONDS=8

# Legacy HOMAGE_* variables are still accepted internally for compatibility.

# Optional metadata-only source connector.
# Do not store full text, download URLs, torrent/IPFS links, or private data.
ATANOR_ANNA_API_ENABLED=0
ATANOR_ANNA_API_ENDPOINT=
ATANOR_ANNA_API_KEY=
ATANOR_ANNA_API_SEARCH_PATH=/api/search
ATANOR_ANNA_API_QUERY_PARAM=q
ATANOR_ANNA_API_LIMIT_PARAM=limit
ATANOR_ANNA_API_MAX_RESULTS=8

# Common Anna's Archive-compatible aliases are also accepted:
# ANNAS_API_ENABLED=1
# ANNAS_BASE_URL=https://your-anna-compatible-api.example
# ANNAS_SECRET_KEY=
